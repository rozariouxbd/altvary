generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Store {
  id              String        @id @default(cuid())
  shopDomain      String        @unique
  // ISO 4217 code (USD, CAD, EUR, GBP…), the shop's default currency from
  // Shopify shop.json. All synced order/customer amounts are already in this
  // currency — it drives display formatting only (no FX conversion).
  currency        String        @default("USD")
  accessToken     String
  // "oauth" = durable offline token from the auth-code flow (external merchants);
  // "client_credentials" = short-lived 24h token re-minted on demand (dev store).
  tokenType       String        @default("oauth")
  // Klaviyo real-time sync (optional). The merchant's Klaviyo private API key,
  // encrypted at rest (lib/crypto), or null when not connected. klaviyoSyncedAt
  // records the last successful bulk reconciliation. klaviyoSyncMode is "auto"
  // (continuous: order webhook + nightly run) or "manual" (only the on-demand
  // "Sync now" button pushes). See lib/klaviyo.ts.
  klaviyoApiKey   String?
  klaviyoSyncedAt DateTime?
  klaviyoSyncMode String        @default("auto")
  // Maps Altvary skincare fields → the merchant's Shopify metafield keys (set via the
  // Day-1 Mapping Wizard), e.g. {"volume":"custom.volume_ml","category":"shopify.product_type"}.
  metafieldMapping Json?
  trialEndsAt     DateTime
  scoringSchedule String        @default("0 2 * * *")
  createdAt       DateTime      @default(now())
  customers       Customer[]
  orders          Order[]
  scoringRuns     ScoringRun[]
  actions         Action[]
  playConfigs     PlayConfig[]
  suppressions    Suppression[]
  scoreHistory    ScoreHistory[]
  products        Product[]
  memberships     Membership[]
  segmentSnapshots SegmentSnapshot[]
  ingredientSuppressions CustomerIngredientSuppression[]
  scoringConfig   ScoringConfig?
}

// Per-store RFME weight customization (Settings → sliders). Weights are stored
// as raw points (0–100 each); the engine normalizes them to sum to 1 at scoring
// time, so the merchant tunes *relative* emphasis without having to make the
// numbers add up themselves. No row ⇒ engine defaults (R35 / F25 / M25 / E15).
model ScoringConfig {
  id        String   @id @default(cuid())
  storeId   String   @unique
  wR        Int      @default(35)
  wF        Int      @default(25)
  wM        Int      @default(25)
  wE        Int      @default(15)
  updatedAt DateTime @updatedAt
  store     Store    @relation(fields: [storeId], references: [id])
}

// One small aggregate row per store per month — macro segment/LTV totals for
// future retention-history trends. Complements the 30-day ScoreHistory prune:
// individual history stays light; macro trend data is preserved cheaply.
model SegmentSnapshot {
  id           String   @id @default(cuid())
  storeId      String
  period       String   // "YYYY-MM"
  capturedAt   DateTime @default(now())
  total        Int
  avgScore     Float
  totalLtv     Float
  vip          Int
  returning    Int
  atRisk       Int
  churning     Int
  lost         Int
  vipLtv       Float
  returningLtv Float
  atRiskLtv    Float
  churningLtv  Float
  lostLtv      Float
  store        Store    @relation(fields: [storeId], references: [id])

  @@unique([storeId, period])
  @@index([storeId, period])
}

// Links a Supabase auth user to a store (tenant) — the basis for auth + access.
model Membership {
  id        String   @id @default(cuid())
  userId    String // supabase auth uid
  email     String
  storeId   String
  role      String   @default("member") // owner | member
  createdAt DateTime @default(now())
  store     Store    @relation(fields: [storeId], references: [id])

  @@unique([userId, storeId])
}

// One row per Shopify product variant — current stock + price for inventory signals.
// Skincare metadata (volumeMl…routineStep) is populated from Shopify metafields via the
// merchant's Store.metafieldMapping; all nullable so the app degrades gracefully when absent.
model Product {
  id           String  @id // shopify variant id
  storeId      String
  productId    String      // shopify product id
  title        String
  sku          String?
  price        Float   @default(0)
  inventoryQty Int     @default(0)
  status       String?
  // Skincare metadata (from metafield mapping)
  volumeMl     Float?      // net contents, ml (drives exhaustion windows)
  dailyUsageMl Float?      // est. usage/day; falls back to a category default in code
  category     String?     // cleanser / serum / moisturizer / sunscreen / …
  collection   String?     // routine/collection grouping
  ingredients  String[]    // active ingredients / actives (for ingredient suppression — later)
  paoDays      Int?        // Period After Opening, days (freshness — later)
  cost         Float?      // unit cost (margin alerts — later)
  marginPct    Float?      // derived margin % (later)
  routineStep  Int?        // position in routine (routine-gap detection — later)
  store        Store         @relation(fields: [storeId], references: [id])

  @@index([storeId])
}

model Customer {
  id          String    @id
  storeId     String
  email       String
  firstName   String?
  lastName    String?
  totalSpent  Float     @default(0)
  orderCount  Int       @default(0)
  lastOrderAt DateTime?
  rfmeR       Float?
  rfmeF       Float?
  rfmeM       Float?
  rfmeE       Float?
  rfmeScore   Float?
  segment     String?
  scoredAt    DateTime?
  // Volumetric exhaustion: soonest product-depletion date across this customer's
  // active products, and days until then. Computed in runScoring from line items.
  replenishDueAt  DateTime?
  daysToDepletion Int?
  // True when that soonest-depleting product is currently out of stock (inventory-aware:
  // hold the replenishment nudge until it's back). Computed alongside replenishDueAt.
  replenishOos    Boolean   @default(false)
  // Missing core routine step (e.g. "Moisturizer") for routine-gap cross-sell, or null
  // if the customer's routine is complete / too sparse to judge. Computed in runScoring.
  routineGap      String?
  // PAO/freshness: soonest date an owned product passes its Period-After-Opening efficacy
  // window (last purchase + paoDays), and days until then. Computed in runScoring.
  freshnessDueAt  DateTime?
  daysToFreshness Int?
  // Margin erosion ("Glow Down"): blended product margin % over the recent window, and the
  // drop in percentage points vs this customer's own prior baseline (positive = eroding toward
  // low-margin/discounted items). Needs Product.cost; computed in runScoring.
  recentMarginPct Float?
  marginDropPct   Float?
  store        Store          @relation(fields: [storeId], references: [id])
  orders       Order[]
  actions      Action[]
  suppressions Suppression[]
  scoreHistory ScoreHistory[]
  ingredientSuppressions CustomerIngredientSuppression[]
}

// Per-customer ingredient exclusions (e.g. after a return citing skin irritation). The
// merchant's flows hide products containing these actives. See lib/shopify.ts refunds/create.
model CustomerIngredientSuppression {
  id         String   @id @default(cuid())
  storeId    String
  customerId String
  ingredient String
  reason     String
  createdAt  DateTime @default(now())
  store      Store    @relation(fields: [storeId], references: [id])
  customer   Customer @relation(fields: [customerId], references: [id])

  @@unique([customerId, ingredient])
  @@index([storeId, customerId])
}

model Order {
  id          String   @id
  storeId     String
  customerId  String
  totalPrice  Float
  refunded    Boolean  @default(false)
  source      String?
  createdAt   DateTime
  store       Store    @relation(fields: [storeId], references: [id])
  customer    Customer @relation(fields: [customerId], references: [id])
  lineItems   OrderLineItem[]
}

// One row per product variant per order — which products were in which order.
// The keystone for skincare features (exhaustion, routine gaps, ingredient suppression…).
model OrderLineItem {
  id         String   @id @default(cuid())
  storeId    String
  orderId    String
  customerId String   // denormalized from Order for fast per-customer × product grouping
  productId  String   // shopify variant id (→ Product.id); may not exist as a Product row
  title      String
  quantity   Int      @default(1)
  price      Float    @default(0)
  lineTotal  Float    @default(0)
  createdAt  DateTime // mirrors the order's createdAt for fast per-product recency
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  // No enforced FK to Product: a line item can reference a variant we don't have a
  // Product row for (deleted/never-synced). Joined to Product by productId in queries.

  @@index([storeId, productId])
  @@index([storeId, customerId])
  @@index([orderId])
}

model ScoringRun {
  id         String    @id @default(cuid())
  storeId    String
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  status     String
  scored     Int       @default(0)
  lockedBy   String?
  // Signature of the normalized RFME weights this run used (see weightsKey in
  // lib/engine/scoring.ts). When it differs from the prior run's, that run
  // rebaselined every score — signals.ts suppresses run-over-run score drops
  // that straddle the change so R04 can't fire spuriously. Null for runs that
  // never completed (and for runs predating this field).
  weights    String?
  store      Store     @relation(fields: [storeId], references: [id])
}

model Action {
  id          String    @id @default(cuid())
  storeId     String
  customerId  String
  playId      String
  exportedAt  DateTime  @default(now())
  convertedAt DateTime?
  converted   Boolean   @default(false)
  store       Store     @relation(fields: [storeId], references: [id])
  customer    Customer  @relation(fields: [customerId], references: [id])
}

// Per-store, per-play mutable state. The play *definition* stays in code (lib/engine/plays).
model PlayConfig {
  id              String    @id @default(cuid())
  storeId         String
  playId          String
  activated       Boolean   @default(false)
  paused          Boolean   @default(false)
  lastExportedAt  DateTime?
  emailTemplateId String?
  discountCode    String?
  discountExpires DateTime?
  store           Store     @relation(fields: [storeId], references: [id])

  @@unique([storeId, playId])
}

// Run-over-run RFME snapshot — one row per customer per scoring run. Enables
// score-drop detection (R04) and score-trend plays.
model ScoreHistory {
  id         String   @id @default(cuid())
  storeId    String
  customerId String
  rfmeR      Float
  rfmeF      Float
  rfmeM      Float
  rfmeE      Float
  rfmeScore  Float
  capturedAt DateTime @default(now())
  store      Store    @relation(fields: [storeId], references: [id])
  customer   Customer @relation(fields: [customerId], references: [id])

  @@index([storeId, customerId, capturedAt])
}

// R03 suppression list — customers excluded from all play exports.
model Suppression {
  id         String   @id @default(cuid())
  storeId    String
  customerId String
  reason     String
  createdAt  DateTime @default(now())
  store      Store    @relation(fields: [storeId], references: [id])
  customer   Customer @relation(fields: [customerId], references: [id])

  @@unique([storeId, customerId])
}
